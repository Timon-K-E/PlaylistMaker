<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_walkman"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:theme="@style/Theme.PlaylistMaker">

    <!-- Кнопка назад -->
    <Button
        android:id="@+id/back_screen_walkman"
        style="@style/ButtonBack"
        android:layout_marginStart="@dimen/element_margin_16"
        android:layout_marginTop="@dimen/element_margin_14"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Секция 1: Обложка альбома (55%) -->
    <ImageView
        android:id="@+id/albumCover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/element_margin_24"
        android:layout_marginTop="@dimen/element_margin_1"
        android:layout_marginEnd="@dimen/element_margin_24"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_placeholder_cover"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_screen_walkman"
        app:layout_constraintHeight_percent="0.55" />

    <!-- Барьер для разделения секций 55% и 25% -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_55"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="albumCover" />

    <!-- Секция 2: Информация и кнопки (25%) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/info_section"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/barrier_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.25">

        <!-- Название песни -->
        <TextView
            android:id="@+id/songTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/element_margin_24"
            android:layout_marginTop="@dimen/element_margin_12"
            android:layout_marginEnd="@dimen/element_margin_24"
            android:fontFamily="@font/ys_display_medium"
            android:gravity="start"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_size_22"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="@string/label_track_name" />

        <!-- Исполнитель -->
        <TextView
            android:id="@+id/artistName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/element_margin_24"
            android:layout_marginTop="@dimen/element_margin_8"
            android:layout_marginEnd="@dimen/element_margin_24"
            android:fontFamily="@font/ys_display_medium"
            android:gravity="start"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_size_14"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/songTitle"
            tools:text="@string/label_track_name" />

        <!-- Барьер для предотвращения наезда кнопок на исполнителя -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_before_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="artistName" />

        <!-- Кнопка добавления в плейлист -->
        <ImageButton
            android:id="@+id/addToPlaylistButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_margin_16"
            android:background="@drawable/ic_circle_background_54"
            android:scaleType="center"
            android:src="@drawable/ic_add_to_playlist_23"
            app:layout_constraintBottom_toBottomOf="@id/playButton"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@id/playButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_before_buttons" />

        <!-- Основная кнопка воспроизведения -->
        <ImageButton
            android:id="@+id/playButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_margin_16"
            android:background="?attr/colorSurface"
            android:scaleType="center"
            android:src="@drawable/ic_play_84"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_before_buttons" />

        <!-- Кнопка добавления в избранное -->
        <ImageButton
            android:id="@+id/addToFavoritesButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_margin_16"
            android:background="@drawable/ic_circle_background_54"
            android:scaleType="center"
            android:src="@drawable/ic_favorite_border_25_23"
            app:layout_constraintBottom_toBottomOf="@id/playButton"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/playButton"
            app:layout_constraintTop_toBottomOf="@id/barrier_before_buttons" />

        <!-- Время воспроизведения -->
        <TextView
            android:id="@+id/timePlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_margin_4"
            android:fontFamily="@font/ys_display_medium"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_size_14"
            app:layout_constraintEnd_toEndOf="@id/playButton"
            app:layout_constraintStart_toStartOf="@id/playButton"
            app:layout_constraintTop_toBottomOf="@id/playButton"
            tools:text="3:45" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Барьер для разделения секций 25% и оставшегося пространства -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_80"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="info_section" />

    <!-- Секция 3: Метаданные (оставшиеся 20%, скроллируемые) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/barrier_80"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/metadataContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_margin_16"
            android:layout_marginBottom="@dimen/element_margin_16"
            android:minHeight="200dp">

            <TextView
                android:id="@+id/durationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/element_margin_16"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="start"
                android:text="@string/label_duration"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_size_13"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="spread" />

            <TextView
                android:id="@+id/durationValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginEnd="@dimen/element_margin_16"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="end"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_13"
                app:layout_constraintBottom_toBottomOf="@id/durationLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/durationLabel"
                app:layout_constraintTop_toTopOf="@id/durationLabel"
                tools:text="3:45" />

            <TextView
                android:id="@+id/albumLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/element_margin_16"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="start"
                android:text="@string/label_album"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/durationLabel" />

            <TextView
                android:id="@+id/albumValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginEnd="@dimen/element_margin_16"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="end"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@id/albumLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/albumLabel"
                app:layout_constraintTop_toTopOf="@id/albumLabel"
                tools:text="Название альбома" />

            <TextView
                android:id="@+id/yearLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/element_margin_16"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="start"
                android:text="@string/label_year"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/albumLabel" />

            <TextView
                android:id="@+id/yearValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginEnd="@dimen/element_margin_16"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="end"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@id/yearLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/yearLabel"
                app:layout_constraintTop_toTopOf="@id/yearLabel"
                tools:text="2023" />

            <TextView
                android:id="@+id/genreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/element_margin_16"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="start"
                android:text="@string/label_genre"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/yearLabel" />

            <TextView
                android:id="@+id/genreValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginEnd="@dimen/element_margin_16"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="end"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@id/genreLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/genreLabel"
                app:layout_constraintTop_toTopOf="@id/genreLabel"
                tools:text="Рок" />

            <TextView
                android:id="@+id/countryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/element_margin_16"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="start"
                android:text="@string/label_country"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/genreLabel" />

            <TextView
                android:id="@+id/countryValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_8"
                android:layout_marginEnd="@dimen/element_margin_16"
                android:layout_marginBottom="@dimen/element_margin_8"
                android:fontFamily="@font/ys_display_regular"
                android:gravity="end"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_13"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@id/countryLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/countryLabel"
                app:layout_constraintTop_toTopOf="@id/countryLabel"
                tools:text="США" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>