<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_walkman"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:theme="@style/Theme.PlaylistMaker">

    <Button
        android:id="@+id/back_screen_walkman"
        style="@style/ButtonBack"
        android:layout_marginStart="@dimen/element_margin_16"
        android:layout_marginTop="@dimen/element_margin_14"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/element_margin_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_max="wrap"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_screen_walkman">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_walkman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/leftGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="@dimen/element_margin_24" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/rightGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="@dimen/element_margin_24" />

            <ImageView
                android:id="@+id/albumCover"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder_cover"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="@id/rightGuideline"
                app:layout_constraintStart_toStartOf="@id/leftGuideline"
                app:layout_constraintTop_toTopOf="@id/container_walkman" />

            <TextView
                android:id="@+id/songTitle"
                style="@style/TextTitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_22"
                app:layout_constraintEnd_toEndOf="@id/rightGuideline"
                app:layout_constraintStart_toStartOf="@id/leftGuideline"
                app:layout_constraintTop_toBottomOf="@id/albumCover"
                tools:text="@string/label_track_name" />

            <TextView
                android:id="@+id/artistName"
                style="@style/TextTitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_14"
                app:layout_constraintEnd_toEndOf="@id/rightGuideline"
                app:layout_constraintStart_toStartOf="@id/leftGuideline"
                app:layout_constraintTop_toBottomOf="@id/songTitle"
                tools:text="@string/label_artist" />

            <FrameLayout
                android:id="@+id/buttonsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_24"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/artistName">

                <ImageButton
                    android:id="@+id/playButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:scaleType="center"
                    android:src="@drawable/ic_play_84"
                    android:visibility="visible" />

                <ImageButton
                    android:id="@+id/pauseButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:scaleType="center"
                    android:src="@drawable/ic_stop_84"
                    android:visibility="invisible" />

            </FrameLayout>

            <ImageButton
                android:id="@+id/addToPlaylistButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_circle_background_51"
                android:scaleType="center"
                android:src="@drawable/ic_add_to_playlist_51_51"
                app:layout_constraintBottom_toBottomOf="@id/buttonsContainer"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="@id/leftGuideline"
                app:layout_constraintTop_toTopOf="@id/buttonsContainer" />

            <ImageButton
                android:id="@+id/addToFavoritesButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_circle_background_51"
                android:scaleType="center"
                android:src="@drawable/ic_favorite_border_51_51"
                app:layout_constraintBottom_toBottomOf="@id/buttonsContainer"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="@id/rightGuideline"
                app:layout_constraintTop_toTopOf="@id/buttonsContainer" />

            <TextView
                android:id="@+id/timePlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_4"
                android:fontFamily="@font/ys_display_medium"
                android:gravity="center"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_14"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonsContainer"
                tools:text="3:45" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/metadataContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/element_margin_30"
                android:layout_marginBottom="@dimen/element_margin_16"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/timePlay">

                <TextView
                    android:id="@+id/durationLabel"
                    style="@style/TextMetadataLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_duration"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="spread" />

                <TextView
                    android:id="@+id/durationValue"
                    style="@style/TextMetadataValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/durationLabel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/durationLabel"
                    app:layout_constraintTop_toTopOf="@id/durationLabel"
                    tools:text="3:45" />

                <TextView
                    android:id="@+id/albumLabel"
                    style="@style/TextMetadataLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_album"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/durationLabel"
                    app:layout_constraintVertical_chainStyle="spread" />

                <TextView
                    android:id="@+id/albumValue"
                    style="@style/TextMetadataValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="@id/albumLabel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/albumLabel"
                    app:layout_constraintTop_toTopOf="@id/albumLabel"
                    tools:text="Название альбома" />

                <TextView
                    android:id="@+id/yearLabel"
                    style="@style/TextMetadataLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_year"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/albumLabel"
                    app:layout_constraintVertical_chainStyle="spread" />

                <TextView
                    android:id="@+id/yearValue"
                    style="@style/TextMetadataValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="@id/yearLabel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/yearLabel"
                    app:layout_constraintTop_toTopOf="@id/yearLabel"
                    tools:text="2023" />

                <TextView
                    android:id="@+id/genreLabel"
                    style="@style/TextMetadataLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_genre"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/yearLabel"
                    app:layout_constraintVertical_chainStyle="spread" />

                <TextView
                    android:id="@+id/genreValue"
                    style="@style/TextMetadataValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="@id/genreLabel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/genreLabel"
                    app:layout_constraintTop_toTopOf="@id/genreLabel"
                    tools:text="Рок" />

                <TextView
                    android:id="@+id/countryLabel"
                    style="@style/TextMetadataLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_country"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/genreLabel"
                    app:layout_constraintVertical_chainStyle="spread" />

                <TextView
                    android:id="@+id/countryValue"
                    style="@style/TextMetadataValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="@id/countryLabel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/countryLabel"
                    app:layout_constraintTop_toTopOf="@id/countryLabel"
                    tools:text="США" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>