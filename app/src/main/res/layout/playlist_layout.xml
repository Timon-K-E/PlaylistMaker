<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:theme="@style/Theme.PlaylistMaker"
    android:layout_marginStart="@dimen/element_margin_13"
    android:layout_marginEnd="@dimen/element_margin_12"
    android:gravity="center_vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="@dimen/track_cover_margin_size"
        android:layout_height="@dimen/track_cover_margin_size"
        app:cardCornerRadius="@dimen/radius_size_2"
        android:layout_marginTop="@dimen/element_margin_8"
        android:layout_marginBottom="@dimen/element_margin_8"
        android:clipChildren="true"
        android:clipToPadding="true"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/CoverTack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="?attr/colorSurface"
            tools:src="@drawable/ic_placeholder_cover"/>

    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/element_margin_8"
        android:layout_marginEnd="@dimen/element_margin_8"
        android:layout_marginTop="@dimen/element_margin_14"
        android:layout_marginBottom="@dimen/element_margin_14"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_playlist_name_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/element_margin_1"
            android:textSize="@dimen/text_size_16"
            android:fontFamily="@font/ys_display_regular"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurface"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="@string/stub_playlist_name"/>

            <TextView
                android:id="@+id/tv_track_count_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_size_artist_name"
                android:fontFamily="@font/ys_display_regular"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="1"
                android:ellipsize="end"
                android:singleLine="true"
                tools:text="@string/stub_number_of_tracks"/>
    </LinearLayout>
</LinearLayout>