<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->

    <style name="Theme.PlaylistMaker"   parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!--Для background главного экрана (меняется при светлой теме)-->
        <item name="colorPrimary">@color/black</item>
        <!--Всё что должно быть белым, всегда -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- background остальных экранов  (меняется при тёмной теме)-->
        <item name="colorSurface">@color/black</item>

        <item name="colorOnSurface">@color/white</item>

        <item name="colorOnSurfaceVariant">@color/white</item>

       <item name="android:windowBackground">@color/black</item>

        <!--Для switch (меняется при светлой теме)-->
        <item name="switchTrackColorChecked">@color/track_color_selector_night</item>
        <item name="switchThumbColorChecked">@color/thumb_color_selector_night</item>
        <item name="switchTrackColorUnchecked">@color/gray_bg_search</item>
        <item name="switchThumbColorUnchecked">@color/gray</item>



    </style>
</resources>