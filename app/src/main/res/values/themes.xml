<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->

    <style name="Theme.PlaylistMaker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
                            <!--background главного экрана (меняется при тёмной теме)-->
        <item name="colorPrimary">@color/blue_main_screen</item>
                            <!--Всё что должно быть белым, всегда -->
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSurface">@color/white</item>

        <item name="colorOnSurface">@color/black</item>

        <item name="colorOnSurfaceVariant">@color/gray</item>

        <item name="android:windowBackground">@color/white</item>


                            <!--Для switch (меняется при тёмной теме)-->
        <item name="switchTrackColorChecked">@color/track_color_selector_light</item>
        <item name="switchThumbColorChecked">@color/thumb_color_selector_light</item>
        <item name="switchTrackColorUnchecked">@color/gray_bg_search</item>
        <item name="switchThumbColorUnchecked">@color/gray</item>


    </style>
</resources>